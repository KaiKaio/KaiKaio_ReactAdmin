{
  "name": "kaikaio-react-admin",
  "version": "0.1.0",
  "private": true,
  "homepage": ".",
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@testing-library/jest-dom": "^4.2.4",
    "@testing-library/react": "^9.3.2",
    "@testing-library/user-event": "^7.1.2",
    "@types/jest": "^24.0.0",
    "@types/node": "^20.0.0",
    "@types/react-loadable": "^5.5.4",
    "@types/react-transition-group": "^4.2.3",
    "ali-oss": "^6.4.0",
    "antd": "^6.3.3",
    "axios": "^1.13.6",
    "dotenv-cli": "^4.0.0",
    "echarts": "^5.5.1",
    "immutability-helper": "^3.1.1",
    "pinyin-pro": "^3.28.0",
    "react": "^19.2.4",
    "react-dnd": "^14.0.2",
    "react-dnd-html5-backend": "^14.0.0",
    "react-dom": "^19.2.4",
    "react-loadable": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-markdown-editor-lite": "^1.4.2",
    "react-router-dom": "^7.13.1",
    "react-transition-group": "^4.3.0",
    "sass": "^1.62.1",
    "typescript": "~5.9.3",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "scripts": {
    "start": "dotenv -e .env.development -- vite",
    "start:windows": "cross-env NODE_OPTIONS=--openssl-legacy-provider dotenv -e .env.development -- vite",
    "start:mac": "dotenv -e .env.development -- vite",
    "start:test": "dotenv -e .env.test -- vite",
    "build": "dotenv -e .env.production -- tsc && vite build",
    "build:test": "dotenv -e .env.test -- tsc && vite build",
    "preview": "vite preview",
    "eslint": "eslint --fix --ext .js --ext .jsx --ext .ts --ext .tsx ./src",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "git add"
    ]
  },
  "pre-commit": [
    "lint-staged"
  ],
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "config-overrides-path": "config-overrides.js",
  "devDependencies": {
    "@types/ali-oss": "^6.16.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "pre-commit": "^1.2.2",
    "vite": "^8.0.1"
  }
}
