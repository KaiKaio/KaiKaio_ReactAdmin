  "scripts": {
    "start": "dotenv -e .env.development -- vite",
    "start:windows": "cross-env NODE_OPTIONS=--openssl-legacy-provider dotenv -e .env.development -- vite",
    "start:mac": "dotenv -e .env.development -- vite",
    "start:test": "dotenv -e .env.test -- vite",
    "build": "dotenv -e .env.production -- tsc && vite build",
    "build:test": "dotenv -e .env.test -- tsc && vite build",
    "preview": "vite preview",
    "eslint": "eslint --fix --ext .js --ext .jsx --ext .ts --ext .tsx ./src",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "git add"
    ]
  },
  "pre-commit": [
    "lint-staged"
  ],
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "config-overrides-path": "config-overrides.js",
  "devDependencies": {
    "@types/ali-oss": "^6.16.11",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^4.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^7.17.0",
    "eslint-config-airbnb": "^18.2.1",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-jsx-a11y": "^6.4.1",
    "eslint-plugin-react": "^7.22.0",
    "eslint-plugin-react-hooks": "^4.2.0",
    "husky": "^4.3.7",
    "lint-staged": "^10.5.3",
    "moment-locales-webpack-plugin": "^1.2.0",
    "pre-commit": "^1.2.2",
    "vite": "^5.2.0"
  }
}
