    "@types/react-router-dom": "^5.1.7",
    "@types/react-transition-group": "^4.2.3",
    "ali-oss": "^6.4.0",
    "antd": "^5.17.0",
    "axios": "^0.21.1",
    "dotenv-cli": "^4.0.0",
    "echarts": "^5.5.1",
    "for-editor": "^0.3.5",
    "immutability-helper": "^3.1.1",
    "moment": "^2.30.1",
    "react": "^18.3.1",
    "react-dnd": "^14.0.2",
    "react-dnd-html5-backend": "^14.0.0",
    "react-dom": "^18.3.1",
    "react-loadable": "^5.5.0",
    "react-router-dom": "^6.23.1",
